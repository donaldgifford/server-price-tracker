package components

import "fmt"

// ScoreBadge renders a colored badge for an alert score. Colors mirror
// the Discord embed colors (green ≥90, yellow 80–89, orange 75–79).
templ ScoreBadge(score int) {
	<span class={ "score-badge", scoreClass(score) }>{ fmt.Sprint(score) }</span>
}

func scoreClass(score int) string {
	switch {
	case score >= 90:
		return "score-green"
	case score >= 80:
		return "score-yellow"
	case score >= 75:
		return "score-orange"
	default:
		return "score-grey"
	}
}
